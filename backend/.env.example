# Скопируй в .env и подставь реальные значения.
# Опционально: другой путь к файлу с секретами (абсолютный или относительно папки backend):
# CONVEER_DOTENV_PATH=C:\secrets\igaming.env
# DATABASE_URL: пароль пользователя postgres — тот, что задавали при установке PostgreSQL (не плейсхолдер ***).
# Спецсимволы в пароле: закодируй в URL (например в Python: urllib.parse.quote_plus("пароль")).
DATABASE_URL=postgresql+asyncpg://postgres:ВАШ_ПАРОЛЬ@127.0.0.1:5432/igaming_factory

REDIS_URL=redis://127.0.0.1:6379/0
JWT_SECRET=длинная-случайная-строка

# Mail.ru SMTP: в SMTP_PASSWORD только «пароль приложения» (настройки почты / безопасность), не пароль входа в ящик.
# https://help.mail.ru/mail/security/protection/external
MAIL_TRANSPORT=smtp
SMTP_HOST=smtp.mail.ru
SMTP_PORT=587
SMTP_USER=your@mail.ru
SMTP_PASSWORD=
MAIL_FROM_EMAIL=your@mail.ru
MAIL_FROM_NAME=Conveer

# Локально: мгновенное тестовое пополнение баланса (POST /api/v1/wallet/mock-topup). На проде — false.
ENABLE_USER_WALLET_MOCK_TOPUP=false

# ЮKassa: shopId и секретный ключ из личного кабинета. Пусто — только mock-топап (если включён).
# В кабинете ЮKassa укажи URL webhook: https://ТВОЙ_ДОМЕН/api/v1/wallet/yookassa/webhook
PUBLIC_APP_URL=http://127.0.0.1:3000
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
